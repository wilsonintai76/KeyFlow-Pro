
{
  "entities": {
    "UserProfile": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "UserProfile",
      "type": "object",
      "description": "Represents a user within the KeyFlow Pro application, focusing on profile details relevant for key assignments and administrative tasks.",
      "properties": {
        "id": {
          "type": "string",
          "description": "Unique identifier for the UserProfile entity (Auth UID)."
        },
        "firstName": {
          "type": "string",
          "description": "The first name of the user."
        },
        "lastName": {
          "type": "string",
          "description": "The last name of the user."
        },
        "email": {
          "type": "string",
          "description": "The primary email address of the user.",
          "format": "email"
        },
        "phoneNumber": {
          "type": "string",
          "description": "The user's contact phone number."
        },
        "employeeId": {
          "type": "string",
          "description": "An optional employee ID or staff number for the user."
        },
        "role": {
          "type": "string",
          "description": "The role of the user within the system.",
          "enum": ["guest", "staff", "admin"]
        }
      },
      "required": [
        "id",
        "firstName",
        "lastName",
        "email",
        "role"
      ]
    },
    "HardwareTrigger": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "HardwareTrigger",
      "type": "object",
      "description": "A signal sent to hardware (ESP32) to perform an action like triggering a solenoid.",
      "properties": {
        "id": { "type": "string" },
        "action": { "type": "string", "enum": ["UNLOCK_CABINET"] },
        "timestamp": { "type": "string", "format": "date-time" },
        "userId": { "type": "string" },
        "status": { "type": "string", "enum": ["pending", "processed"] }
      }
    },
    "Key": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Key",
      "type": "object",
      "description": "Represents a physical key managed by the KeyFlow Pro system.",
      "properties": {
        "id": {
          "type": "string",
          "description": "Unique identifier for the Key entity."
        },
        "keyIdentifier": {
          "type": "string",
          "description": "A human-readable identifier (e.g., 'MAIN-001')."
        },
        "description": {
          "type": "string"
        },
        "location": {
          "type": "string"
        },
        "currentStatus": {
          "type": "string",
          "description": "The current status of the key (e.g., 'available', 'checked_out', 'overdue')."
        },
        "lastAssignedToUserId": {
          "type": "string"
        }
      },
      "required": [
        "id",
        "keyIdentifier",
        "description",
        "location",
        "currentStatus"
      ]
    },
    "GlobalSettings": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "GlobalSettings",
      "type": "object",
      "description": "System-wide configuration settings.",
      "properties": {
        "maxBorrowDurationHours": {
          "type": "integer",
          "description": "Maximum hours a key can be borrowed before considered overdue.",
          "default": 24
        }
      }
    }
  },
  "auth": {
    "providers": [
      "password",
      "anonymous",
      "google"
    ]
  },
  "firestore": {
    "structure": [
      {
        "path": "/user_profiles/{userId}",
        "definition": {
          "entityName": "UserProfile",
          "schema": {
            "$ref": "#/backend/entities/UserProfile"
          },
          "description": "Stores individual user profile data including roles."
        }
      },
      {
        "path": "/hardware_triggers/{triggerId}",
        "definition": {
          "entityName": "HardwareTrigger",
          "schema": {
            "$ref": "#/backend/entities/HardwareTrigger"
          },
          "description": "Collection monitored by ESP32 to trigger solenoids."
        }
      },
      {
        "path": "/keys/{keyId}",
        "definition": {
          "entityName": "Key",
          "schema": {
            "$ref": "#/backend/entities/Key"
          },
          "description": "Main collection for managing the inventory of physical keys."
        }
      },
      {
        "path": "/settings/{settingId}",
        "definition": {
          "entityName": "GlobalSettings",
          "schema": {
            "$ref": "#/backend/entities/GlobalSettings"
          },
          "description": "Global configuration documents."
        }
      }
    ]
  }
}
