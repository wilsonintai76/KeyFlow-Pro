
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * KeyFlow Pro Security Rules
     */

    // --- Helper Functions ---

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    /**
     * @description Checks if the user is an administrator.
     * Prioritizes Master Admin ID and Email for immediate bootstrap access.
     */
    function isAdmin() {
      return isSignedIn() && (
        request.auth.uid == 'cpygG7wuaQVcvOa0bjMCDzNc1DN2' 
        || request.auth.token.email == 'wilsonintai76@gmail.com'
        || (exists(/databases/$(database)/documents/user_profiles/$(request.auth.uid)) && get(/databases/$(database)/documents/user_profiles/$(request.auth.uid)).data.role == 'admin')
      );
    }

    function isStaff() {
      return isAdmin() || (isSignedIn() && exists(/databases/$(database)/documents/user_profiles/$(request.auth.uid)) && get(/databases/$(database)/documents/user_profiles/$(request.auth.uid)).data.role == 'staff');
    }

    // --- Collection Rules ---

    /**
     * @description User Profile management.
     */
    match /user_profiles/{userId} {
      allow get: if isSignedIn();
      allow list: if isAdmin();
      // Allow Wilson to be admin on creation, others default to guest
      allow create: if isOwner(userId) && (request.resource.data.role == 'guest' || userId == 'cpygG7wuaQVcvOa0bjMCDzNc1DN2' || request.auth.token.email == 'wilsonintai76@gmail.com');
      allow update: if isOwner(userId) && (request.resource.data.role == resource.data.role || isAdmin());
      allow delete: if isAdmin();
    }

    /**
     * @description Key inventory. Only admins can modify.
     */
    match /keys/{keyId} {
      allow get, list: if isSignedIn();
      allow create, update, delete: if isAdmin();
    }

    /**
     * @description Key assignments (Checkout/Return). 
     */
    match /assignments/{assignmentId} {
      allow get, list: if isStaff();
      allow create: if isStaff();
      allow update: if isStaff();
      allow delete: if isAdmin();
    }

    /**
     * @description Hardware triggers collection. Only staff and admins can trigger.
     */
    match /hardware_triggers/{triggerId} {
      allow create: if isStaff();
      allow get, list, update, delete: if isStaff();
    }

    /**
     * @description Global system settings. Only admins can modify.
     */
    match /settings/{settingId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }
  }
}
