
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * KeyFlow Pro Security Rules
     */

    // --- Helper Functions ---

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isSignedIn() && exists(/databases/$(database)/documents/administrators/$(request.auth.uid));
    }

    // --- Collection Rules ---

    /**
     * @description User Profile management.
     */
    match /user_profiles/{userId} {
      allow get, list: if isOwner(userId) || isAdmin();
      allow create: if isOwner(userId) && request.resource.data.id == userId;
      allow update: if (isOwner(userId) || isAdmin()) && (resource == null || request.resource.data.id == resource.data.id);
      allow delete: if isAdmin() && resource != null;
    }

    /**
     * @description Administrator registry. Managed manually in Firebase Console.
     */
    match /administrators/{userId} {
      allow get: if isSignedIn();
      allow write: if false; 
    }

    /**
     * @description Key inventory. Only admins can modify.
     */
    match /keys/{keyId} {
      allow get, list: if isSignedIn();
      allow create, update, delete: if isAdmin();
    }

    /**
     * @description Key assignments (Checkout/Return). 
     */
    match /assignments/{assignmentId} {
      allow get, list: if isSignedIn();
      allow create: if isSignedIn() && request.resource.data.assignedToUserId == request.auth.uid;
      allow update: if (isAdmin() || (isSignedIn() && resource.data.assignedToUserId == request.auth.uid)) && resource != null;
      allow delete: if isAdmin() && resource != null;
    }

    /**
     * @description Hardware triggers collection.
     */
    match /hardware_triggers/{triggerId} {
      allow create: if isSignedIn();
      allow get, list, update, delete: if isSignedIn();
    }
  }
}
