rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * KeyFlow Pro Security Rules
     * 
     * Core Philosophy:
     * This ruleset implements a robust, role-based access control system tailored for key management. 
     * It prioritizes "Authorization Independence" by using a dedicated collection for administrator 
     * privileges, ensuring that security checks are performant and decouple permission logic 
     * from profile data.
     * 
     * Data Structure:
     * - /user_profiles/{userId}: Individual user metadata, secured by path-based ownership.
     * - /system_roles/administrators/{userId}: A lookup collection to identify system admins.
     * - /keys/{keyId}: Global inventory of physical assets, readable by all staff.
     * - /assignments/{assignmentId}: Transactional logs of key checkouts.
     * 
     * Key Security Decisions:
     * 1. Admin Identification: Admins are verified via the existence of a document in the 
     *    /system_roles/administrators collection. This avoids complex object parsing in rules.
     * 2. Ownership for Writes: Users can only manage their own profiles and their own 
     *    active assignments (check-ins).
     * 3. Public Inventory: Key availability is treated as public (authenticated) information 
     *     to facilitate a real-time dashboard for all staff members.
     * 4. Relational Integrity: On creation, the system enforces that the 'assignedToUserId' 
     *    in the assignment data matches the authenticated user's ID.
     */

    // --- Helper Functions ---

    /**
     * @description Checks if the request is from an authenticated user.
     */
    function isSignedIn() {
      return request.auth != null;
    }

    /**
     * @description Checks if the authenticated user's ID matches the provided ID.
     * @param userId The ID to compare against the auth UID.
     */
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    /**
     * @description Checks if the authenticated user has an administrator record.
     * This implementation uses "Authorization Independence" via a dedicated roles collection.
     */
    function isAdmin() {
      return isSignedIn() && exists(/databases/$(database)/documents/system_roles/administrators/$(request.auth.uid));
    }

    // The 'isExistingOwner' function was removed as it was unused and contained 
    // a variable name 'resource' which, while referring to the global context variable, 
    // was flagged by the linter as an 'Invalid variable name' in this context. 
    // The explicit 'resource != null' checks are maintained inline where needed.

    // --- Collection Rules ---

    /**
     * @description User Profile management. Users manage themselves; Admins manage everyone.
     * @path /user_profiles/{userId}
     * @allow (get) request.auth.uid == userId
     * @deny (create) request.auth.uid != userId
     * @principle Path-based ownership and relational integrity for profile identity.
     */
    match /user_profiles/{userId} {
      allow get, list: if isOwner(userId) || isAdmin();
      allow create: if isOwner(userId) && request.resource.data.id == userId;
      allow update: if (isOwner(userId) || isAdmin()) && resource != null && request.resource.data.id == resource.data.id;
      allow delete: if isAdmin() && resource != null;
    }

    /**
     * @description Global Administrator role registry. Read by all to verify permissions; managed by existing admins.
     * @path /system_roles/administrators/{userId}
     * @allow (get) Any signed-in user checking a role.
     * @deny (create) Non-admin trying to grant themselves admin status.
     * @principle Role-based access control via a dedicated authorization collection.
     */
    match /system_roles/administrators/{userId} {
      allow get, list: if isSignedIn();
      allow create, update, delete: if isAdmin() && (resource != null || request.method == 'create');
    }

    /**
     * @description Key inventory. Readable by all for the dashboard; managed strictly by admins.
     * @path /keys/{keyId}
     * @allow (list) Any signed-in staff member viewing availability.
     * @deny (update) Staff member trying to change key location.
     * @principle Public-read/Admin-write pattern for shared organizational assets.
     */
    match /keys/{keyId} {
      allow get, list: if isSignedIn();
      allow create: if isAdmin();
      allow update, delete: if isAdmin() && resource != null;
    }

    /**
     * @description Key assignments (Checkout/Return). Admins see all; users see and create their own.
     * @path /assignments/{assignmentId}
     * @allow (create) User checking out a key for themselves.
     * @deny (get) User trying to view someone else's assignment details.
     * @principle Relational integrity enforced during creation; access restricted to involved parties.
     */
    match /assignments/{assignmentId} {
      // Users can only get their own assignments; Admins can see all.
      allow get: if isAdmin() || (isSignedIn() && resource.data.assignedToUserId == request.auth.uid);
      
      // CRITICAL: Path-based or Attribute-based listing. 
      // Admin can list all. Regular users are restricted from general listing of this top-level collection 
      // to protect privacy, requiring specific queries or admin rights.
      allow list: if isAdmin();

      // Users can create assignments only for themselves.
      allow create: if isSignedIn() && request.resource.data.assignedToUserId == request.auth.uid;
      
      // Updates allowed for the owner (e.g., returning a key) or admins.
      allow update: if (isAdmin() || (isSignedIn() && resource.data.assignedToUserId == request.auth.uid)) && resource != null;
      
      // Deletions (cancellations) restricted to administrators.
      allow delete: if isAdmin() && resource != null;
    }
  }
}