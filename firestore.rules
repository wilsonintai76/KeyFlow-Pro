
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * KeyFlow Pro Security Rules - Role Based Access
     */

    // --- Helper Functions ---

    function isSignedIn() {
      return request.auth != null;
    }

    /**
     * @description Checks if the user is an administrator.
     * Primary Admin: wilsonintai76@gmail.com
     */
    function isAdmin() {
      return isSignedIn() && (
        request.auth.token.email == 'wilsonintai76@gmail.com' ||
        request.auth.uid == 'cpygG7wuaQVcvOa0bjMCDzNc1DN2' ||
        (
          exists(/databases/$(database)/documents/user_profiles/$(request.auth.uid)) && 
          get(/databases/$(database)/documents/user_profiles/$(request.auth.uid)).data.role == 'admin'
        )
      );
    }

    function isStaff() {
      return isAdmin() || (
        isSignedIn() && 
        exists(/databases/$(database)/documents/user_profiles/$(request.auth.uid)) && 
        get(/databases/$(database)/documents/user_profiles/$(request.auth.uid)).data.role == 'staff'
      );
    }

    // --- Collection Rules ---

    /**
     * @description User Profile management.
     */
    match /user_profiles/{uid} {
      allow read: if isSignedIn();
      
      // Allow creation if it's the user's own profile
      allow create: if isSignedIn() && request.auth.uid == uid;

      // Allow updates to own profile (metadata only) or full admin control
      allow update: if isAdmin() || (isSignedIn() && request.auth.uid == uid && (
        // Only allow self-update if the role field remains exactly the same as existing data
        request.resource.data.role == resource.data.role
      ));
      
      allow delete: if isAdmin();
    }

    /**
     * @description Key inventory.
     */
    match /keys/{keyId} {
      allow read: if isSignedIn();
      allow create, update, delete: if isAdmin();
    }

    /**
     * @description Activity logs (Checkout/Return). Restricted to Staff and Admins.
     */
    match /assignments/{assignmentId} {
      allow get, list, create, update: if isStaff();
      allow delete: if isAdmin();
    }

    /**
     * @description Hardware triggers collection. Staff can trigger, ESP32 reads.
     */
    match /hardware_triggers/{triggerId} {
      allow read, create, update: if isStaff();
      allow delete: if isAdmin();
    }

    /**
     * @description Cabinet status reported by ESP32.
     */
    match /cabinet_status/{statusId} {
      allow read: if isSignedIn();
      allow write: if isStaff() || isAdmin();
    }

    /**
     * @description Global system settings. Only admins can modify.
     */
    match /settings/{settingId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    /**
     * @description Complaints collection.
     */
    match /complaints/{complaintId} {
      allow create: if isSignedIn();
      allow read, update, delete: if isAdmin();
    }
  }
}
