
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * KeyFlow Pro Security Rules - Role Based Access
     */

    // --- Helper Functions ---

    function isSignedIn() {
      return request.auth != null;
    }

    /**
     * @description Checks if the user is an administrator.
     * Fallback to Master Admin email only if not explicitly demoted in database.
     */
    function isAdmin() {
      return isSignedIn() && (
        request.auth.uid == 'cpygG7wuaQVcvOa0bjMCDzNc1DN2' 
        || request.auth.token.email == 'wilsonintai76@gmail.com'
        || (
          exists(/databases/$(database)/documents/user_profiles/$(request.auth.uid)) && 
          get(/databases/$(database)/documents/user_profiles/$(request.auth.uid)).data.role == 'admin'
        )
      );
    }

    function isStaff() {
      return isAdmin() || (isSignedIn() && exists(/databases/$(database)/documents/user_profiles/$(request.auth.uid)) && get(/databases/$(database)/documents/user_profiles/$(request.auth.uid)).data.role == 'staff');
    }

    // --- Collection Rules ---

    /**
     * @description User Profile management.
     * Users can create/manage their own profiles. Role changes restricted to admins.
     */
    match /user_profiles/{uid} {
      allow read: if isSignedIn();
      // Allow creation/updates for the owner as long as they don't elevate their own role
      allow create, update: if (isSignedIn() && request.auth.uid == uid && (
        !request.resource.data.diff(resource.data).affectedKeys().hasAny(['role']) ||
        isAdmin()
      )) || isAdmin();
      allow delete: if isAdmin();
    }

    /**
     * @description Key inventory. Admins can create and update (for maintenance).
     */
    match /keys/{keyId} {
      allow read: if isSignedIn();
      allow create, update, delete: if isAdmin();
    }

    /**
     * @description Activity logs (Checkout/Return). Restricted to Staff and Admins.
     */
    match /assignments/{assignmentId} {
      allow get, list, create, update: if isStaff();
      allow delete: if isAdmin();
    }

    /**
     * @description Hardware triggers collection. Staff can trigger, ESP32 reads.
     */
    match /hardware_triggers/{triggerId} {
      allow read, create, update: if isStaff();
      allow delete: if isAdmin();
    }

    /**
     * @description Cabinet status reported by ESP32.
     */
    match /cabinet_status/{statusId} {
      allow read: if isSignedIn();
      allow write: if isSignedIn();
    }

    /**
     * @description Global system settings. Only admins can modify.
     */
    match /settings/{settingId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    /**
     * @description Complaints collection.
     */
    match /complaints/{complaintId} {
      allow create: if isSignedIn();
      allow read, update, delete: if isAdmin();
    }
  }
}
