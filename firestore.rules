
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * KeyFlow Pro Security Rules - Role Based Access
     */

    // --- Helper Functions ---

    function isSignedIn() {
      return request.auth != null;
    }

    /**
     * @description Checks if the user is an administrator.
     * Prioritizes Master Admin IDs and Emails for immediate bootstrap access.
     */
    function isAdmin() {
      return isSignedIn() && (
        request.auth.uid == 'cpygG7wuaQVcvOa0bjMCDzNc1DN2' 
        || request.auth.token.email == 'wilsonintai76@gmail.com'
        || request.auth.token.email == 'wilson@poliku.edu.my'
        || (exists(/databases/$(database)/documents/user_profiles/$(request.auth.uid)) && get(/databases/$(database)/documents/user_profiles/$(request.auth.uid)).data.role == 'admin')
      );
    }

    function isStaff() {
      return isAdmin() || (isSignedIn() && exists(/databases/$(database)/documents/user_profiles/$(request.auth.uid)) && get(/databases/$(database)/documents/user_profiles/$(request.auth.uid)).data.role == 'staff');
    }

    // --- Collection Rules ---

    /**
     * @description User Profile management.
     * Users can create/manage their own profiles. Admins can manage all.
     */
    match /user_profiles/{uid} {
      allow read: if isSignedIn();
      // Allow creation/updates if the user is the owner or an admin
      allow create, update: if (isSignedIn() && request.auth.uid == uid) || isAdmin();
      allow delete: if isAdmin();
    }

    /**
     * @description Key inventory. Admins can create and update (for maintenance).
     * Deletion allowed only if status is available.
     */
    match /keys/{keyId} {
      allow read: if isSignedIn();
      allow create: if isAdmin();
      allow update: if isAdmin(); 
      allow delete: if isAdmin() && resource.data.currentStatus == 'available';
    }

    /**
     * @description Activity logs (Checkout/Return). Restricted to Staff and Admins.
     */
    match /assignments/{assignmentId} {
      allow get, list, create, update: if isStaff();
      allow delete: if isAdmin();
    }

    /**
     * @description Hardware triggers collection. Staff can trigger, ESP32 reads.
     */
    match /hardware_triggers/{triggerId} {
      allow read, create, update: if isStaff();
      allow delete: if isAdmin();
    }

    /**
     * @description Cabinet status reported by ESP32.
     */
    match /cabinet_status/{statusId} {
      allow read: if isSignedIn();
      allow write: if isSignedIn();
    }

    /**
     * @description Global system settings. Only admins can modify.
     */
    match /settings/{settingId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    /**
     * @description Complaints collection.
     */
    match /complaints/{complaintId} {
      allow create: if isSignedIn();
      allow read, update, delete: if isAdmin();
    }
  }
}
