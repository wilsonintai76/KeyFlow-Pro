
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * KeyFlow Pro Security Rules - Role Based Access
     */

    // --- Helper Functions ---

    function isSignedIn() {
      return request.auth != null;
    }

    /**
     * @description Checks if the user is an administrator.
     * Primary Admin: wilsonintai76@gmail.com
     */
    function isAdmin() {
      return isSignedIn() && (
        request.auth.token.email == 'wilsonintai76@gmail.com' ||
        exists(/databases/$(database)/documents/user_profiles/$(request.auth.uid)) && 
        get(/databases/$(database)/documents/user_profiles/$(request.auth.uid)).data.role == 'admin'
      );
    }

    function isStaff() {
      // Wilson is always staff as well
      return request.auth.token.email == 'wilsonintai76@gmail.com' || 
             isAdmin() || 
             (isSignedIn() && 
              exists(/databases/$(database)/documents/user_profiles/$(request.auth.uid)) && 
              get(/databases/$(database)/documents/user_profiles/$(request.auth.uid)).data.role == 'staff'
             );
    }

    // --- Collection Rules ---

    match /user_profiles/{uid} {
      allow read: if isSignedIn();
      // Allow Wilson or Admins to create/update
      allow create: if isSignedIn() && (request.auth.uid == uid || isAdmin());
      allow update: if isSignedIn() && (request.auth.uid == uid || isAdmin());
      allow delete: if isAdmin();
    }

    match /keys/{keyId} {
      allow read: if isSignedIn();
      allow create, update, delete: if isAdmin();
    }

    match /hardware_triggers/{triggerId} {
      allow read, create, update: if isStaff();
      allow delete: if isAdmin();
    }

    match /cabinet_status/{statusId} {
      allow read: if isSignedIn();
      allow write: if isStaff() || isAdmin();
    }

    match /settings/{settingId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    match /complaints/{complaintId} {
      allow create: if isSignedIn();
      allow read, update, delete: if isAdmin();
    }

    match /system_logs/{logId} {
      allow read: if isAdmin() || isStaff();
      allow create: if isSignedIn();
    }
  }
}
